@model MecHub.ViewModel.VeiculoAtualizarStatusViewModel
@using MecHub.Models

@{
    ViewData["Title"] = "Atualizar Status do Veículo";
}

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">Atualizar Status do Veículo</h4>
        </div>

        <div class="card-body">
            <div class="mb-3">
                <p><strong>Veículo:</strong> @Model.Marca @Model.Modelo</p>
                <p><strong>Placa:</strong> @Model.Placa</p>
            </div>

            <form asp-action="AtualizarStatus" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="StatusAtual" class="form-label"></label>
                    <select asp-for="StatusAtual" class="form-select"
                            asp-items="Html.GetEnumSelectList<StatusVeiculoEnum>()">
                    </select>
                    <span asp-validation-for="StatusAtual" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ObservacaoStatus" class="form-label"></label>
                    <textarea asp-for="ObservacaoStatus" class="form-control" rows="4"
                              placeholder="Ex: veículo em avaliação, aguardando peças, reparo em andamento..."></textarea>
                    <span asp-validation-for="ObservacaoStatus" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-success">
                    Salvar Status
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Voltar
                </a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}