@model MecHub.ViewModel.ClienteEditViewModel

@{
    Layout = "~/Views/Shared/_LayoutMecanico.cshtml";
    ViewData["Title"] = "Editar Cliente";
}

<link rel="stylesheet" href="~/css/forms.css" asp-append-version="true" />

<section class="cliente-page">

    <div class="cliente-header">
        <div>
            <span class="cliente-eyebrow">Edição</span>
            <h1>Editar Cliente</h1>
            <p>Atualize os dados cadastrais do cliente.</p>
        </div>

        <a asp-controller="Cliente"
           asp-action="Index"
           class="btn-fechar">
            x
        </a>
    </div>

    <div class="cliente-card">

        <form asp-controller="Cliente"
              asp-action="Editar"
              asp-route-id="@Model.Id"
              method="post">

            @Html.AntiForgeryToken()

            <input asp-for="Id" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-section-title">
                <h4>Dados do cliente</h4>
                <p>Revise e altere as informações principais do cliente.</p>
            </div>

            <div class="row g-4">

                <div class="col-md-6">
                    <label asp-for="Nome" class="form-label">Nome completo</label>

                    <input asp-for="Nome"
                           class="form-control input-dark"
                           placeholder="Ex: João da Silva" />

                    <span asp-validation-for="Nome" class="field-error"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Email" class="form-label">E-mail</label>

                    <input asp-for="Email"
                           class="form-control input-dark"
                           placeholder="cliente@email.com" />

                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Telefone" class="form-label">Telefone</label>

                    <input asp-for="Telefone"
                           class="form-control input-dark"
                           placeholder="(11) 99999-9999" />

                    <span asp-validation-for="Telefone" class="field-error"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Cpf" class="form-label">CPF</label>

                    <input asp-for="Cpf"
                           class="form-control input-dark"
                           placeholder="Somente números"
                           maxlength="11" />

                    <span asp-validation-for="Cpf" class="field-error"></span>
                </div>

            </div>

            <div class="cliente-info-box">
                <strong>Atenção:</strong>
                alterar os dados do cliente pode impactar veículos associados, consultas e ordens de serviço vinculadas.
            </div>

            <div class="acoes-form">

                <a asp-controller="Cliente"
                   asp-action="Index"
                   class="btn-cancelar">
                    Cancelar
                </a>

                <button type="submit" class="btn-salvar">
                    Salvar Alterações
                </button>

            </div>

        </form>

    </div>

</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}