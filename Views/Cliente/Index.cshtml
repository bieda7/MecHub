@model IEnumerable<MecHub.ViewModel.ClienteListViewModel>

@{
    Layout = "~/Views/Shared/_LayoutMecanico.cshtml";
    ViewData["Title"] = "Clientes";
}

<link rel="stylesheet" href="~/css/listas.css" asp-append-version="true" />

<section class="clientes-page">

    <div class="clientes-header">
        <div>
            <h1>Clientes</h1>
            <p>Gerencie os clientes cadastrados no sistema.</p>
        </div>

        <a asp-controller="Cliente" asp-action="Criar" class="btn-novo-cliente">
            + Novo Cliente
        </a>
    </div>

    <div class="clientes-card">

        @if (Model == null || !Model.Any())
        {
            <div class="empty-state">

                <h2>Nenhum cliente cadastrado</h2>

                <p>
                    Cadastre o primeiro cliente para começar
                    a registrar veículos e ordens de serviço.
                </p>

                <a asp-controller="Cliente" asp-action="Criar" class="btn-novo-cliente">
                    Cadastrar Cliente
                </a>

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="clientes-table">

                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Cliente</th>
                            <th>Email</th>
                            <th>Telefone</th>
                            <th>CPF</th>
                            <th class="acoes-col">Ações</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var cliente in Model)
                        {
                            <tr>

                                <td>
                                    #@cliente.Id
                                </td>

                                <td>
                                    <strong>@cliente.Nome</strong>
                                </td>

                                <td>
                                    @cliente.Email
                                </td>

                                <td>
                                    @cliente.Telefone
                                </td>

                                <td>
                                    @cliente.Cpf
                                </td>

                                <td class="acoes">

                                    @* <a asp-controller="Cliente"
                                       asp-action="Detalhes"
                                       asp-route-id="@cliente.Id"
                                       class="btn-acao detalhes">
                                        Detalhes
                                    </a> *@

                                    <a asp-controller="Cliente" asp-action="Editar" asp-route-id="@cliente.Id"
                                           class="btn-acao editar">
                                        Editar
                                    </a>

                                    <button type="button" class="btn-acao excluir" data-bs-toggle="modal"
                                            data-bs-target="#deleteModal"
                                            data-delete-action="@Url.Action("DeletarConfirmado", "Cliente", new { id = cliente.Id })"
                                            data-delete-message="Você tem certeza que deseja excluir esse dado permanentemente do sistema? Essa ação é irreversível.">
                                        Excluir
                                    </button>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

    </div>

</section>