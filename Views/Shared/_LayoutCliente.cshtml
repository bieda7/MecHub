@using System.Security.Claims

@{
    var nomeUsuario = User.Identity?.Name ?? "Cliente";
    var userEmail = User.FindFirst(ClaimTypes.Email)?.Value ?? "";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - MecHub Cliente</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        :root {
            --mechub-red: #FF022E;
            --mechub-red-hover: #d90027;
            --mechub-dark: #1f1f1f;
            --mechub-darker: #141414;
            --mechub-light: #f5f6fa;
            --mechub-card: #ffffff;
            --mechub-border: #e5e7eb;
            --mechub-muted: #6b7280;
        }

        body {
            margin: 0;
            background: var(--mechub-light);
            font-family: Arial, Helvetica, sans-serif;
        }

        .cliente-wrapper {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .cliente-navbar {
            background: var(--mechub-dark);
            color: white;
            padding: 18px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 4px 18px rgba(0, 0, 0, 0.18);
        }

        .cliente-logo {
            font-size: 1.55rem;
            font-weight: 800;
            color: white;
            text-decoration: none;
        }

        .cliente-logo span {
            color: var(--mechub-red);
        }

        .cliente-nav-links {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .cliente-nav-link {
            color: #e5e7eb;
            text-decoration: none;
            padding: 9px 14px;
            border-radius: 10px;
            transition: 0.2s;
            font-size: 0.95rem;
        }

        .cliente-nav-link:hover {
            background: var(--mechub-red);
            color: white;
        }

        .cliente-user-box {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .cliente-avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: var(--mechub-red);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            color: white;
        }

        .cliente-user-name {
            font-weight: 600;
            line-height: 1.1;
        }

        .cliente-user-email {
            font-size: 0.78rem;
            color: #c9c9c9;
        }

        .cliente-hero {
            background: linear-gradient(135deg, #1f1f1f, #141414);
            color: white;
            padding: 46px 32px;
            border-bottom: 5px solid var(--mechub-red);
        }

        .cliente-hero-content {
            max-width: 1180px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            gap: 28px;
            align-items: center;
        }

        .cliente-hero h1 {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 10px;
        }

        .cliente-hero p {
            color: #d1d5db;
            max-width: 650px;
            margin-bottom: 0;
        }

        .hero-card {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 18px;
            padding: 20px;
            min-width: 260px;
        }

        .hero-card strong {
            display: block;
            font-size: 1.1rem;
        }

        .hero-card small {
            color: #d1d5db;
        }

        .cliente-main {
            flex: 1;
            width: 100%;
            max-width: 1180px;
            margin: -24px auto 0;
            padding: 0 24px 36px;
        }

        .cliente-content-card {
            background: var(--mechub-card);
            border-radius: 20px;
            border: 1px solid var(--mechub-border);
            box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
            padding: 28px;
        }

        .btn-mechub {
            background: var(--mechub-red);
            color: white;
            border: none;
            border-radius: 10px;
            padding: 10px 18px;
        }

        .btn-mechub:hover {
            background: var(--mechub-red-hover);
            color: white;
        }

        .btn-outline-mechub {
            color: var(--mechub-red);
            border: 1px solid var(--mechub-red);
            border-radius: 10px;
            padding: 10px 18px;
            background: transparent;
        }

        .btn-outline-mechub:hover {
            background: var(--mechub-red);
            color: white;
        }

        .cliente-footer {
            background: var(--mechub-dark);
            color: #d1d5db;
            padding: 18px 32px;
            text-align: center;
            font-size: 0.9rem;
        }

        .status-shortcuts {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
            margin-bottom: 22px;
        }

        .shortcut-card {
            flex: 1;
            min-width: 210px;
            background: white;
            border: 1px solid var(--mechub-border);
            border-radius: 16px;
            padding: 18px;
            text-decoration: none;
            color: var(--mechub-dark);
            transition: 0.2s;
        }

        .shortcut-card:hover {
            transform: translateY(-2px);
            border-color: var(--mechub-red);
            color: var(--mechub-dark);
            box-shadow: 0 8px 18px rgba(0,0,0,0.08);
        }

        .shortcut-icon {
            font-size: 1.6rem;
            margin-bottom: 8px;
        }

        .logout-inline-form {
            margin: 0;
        }

        .logout-link-btn {
            background: transparent;
            color: #e5e7eb;
            border: 1px solid #444;
            padding: 9px 14px;
            border-radius: 10px;
            transition: 0.2s;
        }

        .logout-link-btn:hover {
            background: var(--mechub-red);
            border-color: var(--mechub-red);
            color: white;
        }

        @@media (max-width: 900px) {
            .cliente-navbar {
                flex-direction: column;
                gap: 16px;
                align-items: flex-start;
            }

            .cliente-nav-links {
                flex-wrap: wrap;
            }

            .cliente-hero-content {
                flex-direction: column;
                align-items: flex-start;
            }

            .hero-card {
                width: 100%;
            }
        }
    </style>
</head>

<body>
    <div class="cliente-wrapper">

        <header class="cliente-navbar">
            <a asp-controller="Home" asp-action="Index" class="cliente-logo">
                Mec<span>Hub</span>
            </a>

            <nav class="cliente-nav-links">
                <a asp-controller="ConsultaVeiculo" asp-action="Index" class="cliente-nav-link">
                    🔎 Consultar veículo
                </a>

                <a asp-controller="Home" asp-action="Index" class="cliente-nav-link">
                    🏠 Página inicial
                </a>

                <a asp-controller="Contato" asp-action="Index" class="cliente-nav-link">
                    📞 Contato
                </a>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form asp-controller="Auth" asp-action="Logout" method="post" class="logout-inline-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="logout-link-btn">
                            🚪 Sair
                        </button>
                    </form>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="LoginLocal" class="cliente-nav-link">
                        🔐 Entrar
                    </a>
                }
            </nav>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="cliente-user-box">
                    <div class="cliente-avatar">
                        @nomeUsuario.Substring(0, 1).ToUpper()
                    </div>

                    <div>
                        <div class="cliente-user-name">@nomeUsuario</div>
                        <div class="cliente-user-email">@userEmail</div>
                    </div>
                </div>
            }
        </header>

        <section class="cliente-hero">
            <div class="cliente-hero-content">
                <div>
                    <h1>@ViewData["Title"]</h1>
                    <p>
                        Acompanhe o andamento da avaliação, aprovação da OS, reparo e retirada do seu veículo de forma simples e segura.
                    </p>
                </div>

                <div class="hero-card">
                    <strong>Consulta por placa</strong>
                    <small>Tenha acesso rápido ao status atualizado pelo mecânico responsável.</small>
                </div>
            </div>
        </section>

        <main class="cliente-main">

            <div class="status-shortcuts">
                <a asp-controller="ConsultaVeiculo" asp-action="Index" class="shortcut-card">
                    <div class="shortcut-icon">🚗</div>
                    <strong>Consultar status</strong>
                    <p class="text-muted mb-0">Veja o andamento do seu veículo pela placa.</p>
                </a>

                <a asp-controller="ConsultaVeiculo" asp-action="Index" class="shortcut-card">
                    <div class="shortcut-icon">📄</div>
                    <strong>Ordem de Serviço</strong>
                    <p class="text-muted mb-0">Acesse o PDF da OS quando disponível.</p>
                </a>

                <a asp-controller="Home" asp-action="Index" class="shortcut-card">
                    <div class="shortcut-icon">🛠️</div>
                    <strong>Suporte</strong>
                    <p class="text-muted mb-0">Entre em contato com a oficina se precisar.</p>
                </a>
            </div>

            <section class="cliente-content-card">

                @if (TempData["Sucesso"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["Sucesso"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @if (TempData["Erro"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["Erro"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()
            </section>
        </main>

        <footer class="cliente-footer">
            MecHub © @DateTime.Now.Year — Portal do Cliente
        </footer>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>