<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MecHub</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/mecanico.css" asp-append-version="true" />
</head>

<body>
    <div class="dashboard-layout">

        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="sidebar-brand">
                <span>Mec</span>Hub
            </div>

            <nav class="sidebar-nav">
                <a asp-controller="Mecanico" asp-action="Index" class="nav-item active">🏠 Dashboard</a>
                <a asp-controller="OrdemServico" asp-action="Index" class="nav-item">📋 Ordens de Serviço</a>
                <a asp-controller="Servico" asp-action="Index" class="nav-item">🛠️ Serviços</a>
                <a asp-controller="Servico" asp-action="Criar" class="nav-item">➕ Novo Serviço</a>
                <a asp-controller="Veiculo" asp-action="Index" class="nav-item">🚗 Veículos</a>
                <a asp-controller="Cliente" asp-action="Index" class="nav-item">👥 Clientes</a>
            </nav>

            <form asp-controller="Auth" asp-action="Logout" method="post" class="logout-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="logout-btn">🚪 Sair</button>
            </form>
        </aside>

        <!-- CONTEÚDO -->
        <main class="content">
            @RenderBody()
        </main>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>