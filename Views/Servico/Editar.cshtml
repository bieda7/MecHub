@model MecHub.ViewModel.ServicoEditViewModel

@{
    Layout = "~/Views/Shared/_LayoutMecanico.cshtml";
    ViewData["Title"] = "Editar Serviço";
}

<link rel="stylesheet" href="~/css/forms.css" asp-append-version="true" />

<section class="form-page">

    <div class="form-header">
        <div>
            <span class="form-eyebrow">Edição</span>
            <h1>Editar Serviço</h1>
            <p>Atualize os dados do serviço utilizado nas ordens de serviço.</p>
        </div>

        <a asp-controller="Servico"
           asp-action="Index"
           class="btn-close-form">
            ×
        </a>
    </div>

    <div class="form-card">

        <form asp-controller="Servico"
              asp-action="Editar"
              asp-route-id="@Model.Id"
              method="post">

            @Html.AntiForgeryToken()

            <input asp-for="Id" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-section-title">
                <h4>Dados do serviço</h4>
                <p>Revise a descrição, categoria e valor base do serviço.</p>
            </div>

            <div class="row g-4">

                <div class="col-md-6">
                    <label asp-for="Descricao" class="form-label">Descrição</label>

                    <input asp-for="Descricao"
                           class="form-control input-dark"
                           placeholder="Ex: Troca de óleo" />

                    <span asp-validation-for="Descricao" class="field-error"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Tipo" class="form-label">Tipo</label>

                    <input asp-for="Tipo"
                           class="form-control input-dark"
                           placeholder="Ex: Manutenção preventiva" />

                    <span asp-validation-for="Tipo" class="field-error"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Valor" class="form-label">Valor</label>

                    <input asp-for="Valor"
                           class="form-control input-dark"
                           placeholder="Ex: 150,00" />

                    <span asp-validation-for="Valor" class="field-error"></span>
                </div>

            </div>

            <div class="form-info-box">
                <strong>Atenção:</strong>
                alterar o valor do serviço pode impactar novas ordens de serviço geradas a partir deste cadastro.
            </div>

            <div class="form-actions">

                <a asp-controller="Servico"
                   asp-action="Index"
                   class="btn-cancel">
                    Cancelar
                </a>

                <button type="submit" class="btn-save">
                    Salvar Alterações
                </button>

            </div>

        </form>

    </div>

</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}